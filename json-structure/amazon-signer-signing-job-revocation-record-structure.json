{
  "type": "object",
  "$schema": "https://json-structure.org/meta/core/v0/#",
  "$id": "https://raw.githubusercontent.com/api-evangelist/amazon-signer/refs/heads/main/json-structure/amazon-signer-signing-job-revocation-record-structure.json",
  "name": "SigningJobRevocationRecord",
  "description": "Revocation information for a signing job.",
  "properties": {
    "reason": {
      "allOf": [
        {
          "type": "string"
        },
        {
          "description": "A caller-supplied reason for revocation."
        }
      ]
    },
    "revokedAt": {
      "allOf": [
        {
          "type": "datetime"
        },
        {
          "description": "The time of revocation."
        }
      ]
    },
    "revokedBy": {
      "allOf": [
        {
          "type": "string"
        },
        {
          "description": "The identity of the revoker."
        }
      ]
    }
  }
}