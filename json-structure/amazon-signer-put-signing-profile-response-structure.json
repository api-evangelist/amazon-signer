    },
    "profileVersion": {
      "allOf": [
        {
          "type": "string",
          "pattern": "^[a-zA-Z0-9]{10}$",
          "minLength": 10,
          "maxLength": 10
        },
        {
          "description": "The version of the signing profile being created."
        }
      ]
    },
    "profileVersionArn": {
      "allOf": [
        {
          "type": "string",
          "minLength": 20,
          "maxLength": 2048
        },
        {
          "description": "The signing profile ARN, including the profile version."
        }
      ]
    }
  }
